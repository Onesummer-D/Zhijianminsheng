        }
    """) as demo:
        
        gr.Markdown("""
        <div style="margin-left: 0px; font-size: 24px; font-weight: bold;">🔍智检民声 - 12345涉检线索智能筛查系统</div>
    """, elem_classes=["main-title"])
        
        with gr.Row():
            with gr.Column(scale=1):
