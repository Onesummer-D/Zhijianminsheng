            margin-top: 0px !important;
        }
        .law-content {
            font-size: 15px;
            color: #333;
            margin-left: 0;
        }
    """) as demo:
        
        gr.Markdown("""
        <div style="margin-left: 0px; font-size: 24px; font-weight: bold;">🔍智检民声 - 12345涉检线索智能筛查系统</div>
    """""")