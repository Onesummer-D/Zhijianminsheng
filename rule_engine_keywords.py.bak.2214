def _match_keyword(text: str, keyword: str) -> bool:
    """简化版：只保留精确匹配和jieba分词，去掉字级模糊（提速50%）"""
    if not text or not keyword:
        return False
    
    text = str(text).lower()
    keyword = str(keyword).lower()
    
    # 层1：精确子串（最快）
    if keyword in text:
        return True
    
    # 层2：jieba分词（中等速度）
    text_words = list(jieba.cut(text))
    kw_words = list(jieba.cut(keyword))
    
    if len(kw_words) == 1:
        return kw_words[0] in text_words
    
    try:
        idx = text_words.index(kw_words[0])
        for kw in kw_words[1:]:
            found = False
            for i in range(idx+1, min(idx+3, len(text_words))):  # 缩小搜索范围提速
                if text_words[i] == kw:
                    idx = i
                    found = True
                    break
            if not found:
                return False
        return True
    except:
        return False
    # 删除层3字级模糊匹配（最慢且容易误伤）

def _check_excluded(text: str):
    """
    检查是否命中全局排除词
    返回: (是否被排除, 命中的排除词)
    """
    if not text:
        return False, None
    text_lower = text.lower()
    for excluded_word in EXCLUDED_WORDS:
        if _match_keyword(text_lower, excluded_word):
            return True, excluded_word
    return False, None

def check_excluded(text: str):
    """供外部调用的排除词检测接口"""
    return _check_excluded(text)

def calculate_confidence(text: str, category: str) -> dict:
    """
    双层级权重算法 + 智能软过滤策略
    排除词不再一刀切：
    - 高置信度(≥6分) + 排除词 → 保留，降级为"中"
    - 中置信度(3-5分) + 排除词 → 保留，降级为"低"
    - 低置信度(<3分) + 排除词 → 硬过滤（维持现状）
    """
    if not text or not isinstance(text, str):
        return {"score": 0, "confidence": "低", "matched_core": [], "matched_feature": [], "is_excluded": False}
    
    if category not in KEYWORDS_DB:
        return {"score": 0, "confidence": "低", "matched_core": [], "matched_feature": [], "is_excluded": False}
    
    cat_data = KEYWORDS_DB[category]
    score = 0
    matched_core = []
    matched_feature = []
    
    # 1. 先计算线索分数（不管排除词）
    for word, weight in cat_data.get("核心定性词", {}).items():
        if _match_keyword(text, word):
            score += weight
            matched_core.append(word)
    
    for word, weight in cat_data.get("特征词", {}).items():
        if _match_keyword(text, word):
            score += weight
            matched_feature.append(word)
    
    # 2. 再检查排除词（软过滤逻辑）
    is_excluded, excluded_word = _check_excluded(text)
    
    if is_excluded:
        if score >= 6:
            # 强线索覆盖弱排除：保留，但降级为"中"
            return {
                "score": score,
                "confidence": "中",
                "matched_core": matched_core,
                "matched_feature": matched_feature,
                "is_excluded": True,
                "exclude_reason": "命中排除词：\"" + excluded_word + "\"，但线索强度高",
                "override_excluded": True,  # 标记为覆盖排除
                "department": cat_data.get("对应部门", "")
            }
        elif score >= 3:
            # 中等线索：保留，但标记为低置信度
            return {
                "score": score,
                "confidence": "低",
                "matched_core": matched_core,
                "matched_feature": matched_feature,
                "is_excluded": True,
                "exclude_reason": "命中排除词：\"" + excluded_word + "\"，线索强度中等",
                "override_excluded": True,
                "department": cat_data.get("对应部门", "")
            }
        else:
            # 弱线索+排除词：硬过滤（维持现状）
            return {
                "score": 0,
                "confidence": "低",
                "matched_core": [],
                "matched_feature": [],
                "is_excluded": True,
                "exclude_reason": "命中排除词：\"" + excluded_word + "\"，且无有效线索",
                "override_excluded": False,
                "department": cat_data.get("对应部门", "")
            }
    
    # 3. 正常置信度分级（无排除词）
    if score >= 6:
        conf_level = "高"
    elif score >= 3:
        conf_level = "中"
    else:
        conf_level = "低"
    
    return {
        "score": score,
        "confidence": conf_level,
        "matched_core": matched_core,
        "matched_feature": matched_feature,
        "is_excluded": False,
        "department": cat_data.get("对应部门", "")
    }

def keyword_match(text: str) -> str:
    """遍历所有类别，返回得分最高的类别（阈值3分，采用软过滤策略）"""
    if not text:
        return None
    
    best_cat = None
    best_score = 0
    best_override = False
    
    for cat in KEYWORDS_DB.keys():
        result = calculate_confidence(text, cat)
        # 优先选择能覆盖排除词的强线索，其次是正常高分线索
        if result.get("override_excluded") and result["score"] >= best_score:
            best_score = result["score"]
            best_cat = cat
            best_override = True
        elif not result.get("is_excluded") and result["score"] > best_score:
            best_score = result["score"]
            best_cat = cat
    
    # 如果最佳结果是强线索覆盖排除词，或者正常高分，都返回
    if best_cat and (best_override or best_score >= 3):
        return best_cat
    
    return None
